// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Skill Telemetry Models ───
// Tracks individual skill invocations for observability.

model SkillInvocation {
  id         String   @id @default(cuid())
  skillId    String                          // e.g. "S01"
  skillName  String                          // e.g. "Stitch Design"
  pipelineId String?                         // null if invoked standalone
  status     String   @default("pending")    // pending | running | success | failed | rolled_back
  durationMs Int?                             // execution duration in milliseconds
  errorMsg   String?                         // error message if failed
  inputHash  String?                         // hash of input data for deduplication
  outputHash String?                         // hash of output data
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([skillId])
  @@index([pipelineId])
  @@index([status])
  @@index([createdAt])
}

// ─── Pipeline Execution Model ───
// Tracks end-to-end pipeline runs with stage-level granularity.

model PipelineExecution {
  id            String   @id @default(cuid())
  name          String?                          // optional user-provided name
  skillIds      String                          // JSON array of skill IDs in pipeline order
  status        String   @default("pending")     // pending | running | success | partial_failure | failed
  completedAt   DateTime?
  totalDurationMs Int?
  successCount  Int      @default(0)
  failureCount  Int      @default(0)
  rollbackCount Int      @default(0)
  errorMsg      String?                          // top-level error if pipeline aborted
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stages       PipelineStage[]

  @@index([status])
  @@index([createdAt])
}

// ─── Pipeline Stage Model ───
// Individual stage within a pipeline execution.

model PipelineStage {
  id            String   @id @default(cuid())
  pipelineId    String
  skillId       String
  skillName     String
  stageIndex    Int                              // 0-based execution order
  status        String   @default("pending")     // pending | running | success | failed | skipped | rolled_back
  durationMs    Int?
  errorMsg      String?
  inputSummary  String?                          // JSON summary of inputs
  outputSummary String?                          // JSON summary of outputs
  rollbackResult String?                         // JSON result of rollback if executed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pipeline      PipelineExecution @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
  @@index([skillId])
  @@index([status])
}

// ─── Skill Version Model ───
// Tracks version history for each skill.

model SkillVersion {
  id          String   @id @default(cuid())
  skillId     String                          // e.g. "S01"
  version     String                          // semver, e.g. "1.0.0"
  schemaHash  String                          // hash of skill definition for change detection
  deprecated  Boolean  @default(false)
  deprecatedAt DateTime?
  createdAt   DateTime @default(now())

  @@unique([skillId, version])
  @@index([skillId])
}